Task 291: Co-working Space
START
    BEGIN
CLASS MembershipPlan
    ATTRIBUTES
        PRIVATE planName : String
        PRIVATE monthlyQuotaHours : Number

CONSTRUCTOR(planName, monthlyQuotaHours)
        SET planName
        SET monthlyQuotaHours
END CONSTRUCTOR

METHOD getQuota()
        RETURN monthlyQuotaHours
    END METHOD
END CLASS
CLASS Member
    ATTRIBUTES
        PRIVATE memberID : Number
        PRIVATE memberName : String
        PRIVATE plan : MembershipPlan
        PRIVATE bookings : List<Booking>

CONSTRUCTOR(memberID, memberName, plan)
        SET memberID
        SET memberName
        SET plan
        CREATE empty bookings list
END CONSTRUCTOR
METHOD addBooking(booking)
        ADD booking TO bookings
END METHOD
METHOD getRemainingHours()
        SET usedHours = 0
        FOR EACH booking IN bookings
            SET usedHours = usedHours + booking.getDuration()
        END FOR
        RETURN plan.getQuota() - usedHours
END METHOD
END CLASS
CLASS Room
    ATTRIBUTES
        PRIVATE roomID : Number
        PRIVATE roomName : String
        PRIVATE bookings : List<Booking>
CONSTRUCTOR(roomID, roomName)
        SET roomID
        SET roomName
        CREATE empty bookings list
END CONSTRUCTOR
METHOD addBooking(booking)
        ADD booking TO bookings
END METHOD
METHOD isAvailable(startTime, endTime)
        FOR EACH booking IN bookings
            IF booking.overlaps(startTime, endTime) THEN
          RETURN FALSE
        END IF
    END FOR
    RETURN TRUE
END METHOD
END CLASS
CLASS Booking
    ATTRIBUTES
        PRIVATE bookingID : Number
        PRIVATE member : Member
        PRIVATE room : Room
        PRIVATE startTime : String
        PRIVATE endTime : String
        PRIVATE duration : Number
CONSTRUCTOR(bookingID, member, room, startTime, endTime, duration)
        SET bookingID
        SET member
        SET room
        SET startTime
        SET endTime
        SET duration
END CONSTRUCTOR
METHOD getDuration()
        RETURN duration
END METHOD
METHOD overlaps(startTime, endTime)
        IF startTime < endTime AND endTime > startTime THEN
            RETURN TRUE
        ELSE
            RETURN FALSE
        END IF
    END METHOD
END CLASS

   END
STOP


