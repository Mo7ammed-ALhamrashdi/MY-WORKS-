START
    BEGIN
CLASS Question
    ATTRIBUTES
        PRIVATE questionText : String
        PRIVATE correctAnswer : String
        PRIVATE points : Number
CONSTRUCTOR(questionText, correctAnswer, points)
        SET questionText
        SET correctAnswer
        SET points
END CONSTRUCTOR
METHOD checkAnswer(answer)
        RETURN answer = correctAnswer
END METHOD
METHOD getPoints()
        RETURN points
END METHOD
END CLASS
CLASS Exam
    ATTRIBUTES
        PRIVATE examID : Number
        PRIVATE examTitle : String
        PRIVATE timeLimit : Number
        PRIVATE questions : List<Question>
CONSTRUCTOR(examID, examTitle, timeLimit)
        SET examID
        SET examTitle
        SET timeLimit
        CREATE empty questions list
END CONSTRUCTOR
METHOD addQuestion(question)
        ADD question TO questions
END METHOD
END CLASS
CLASS Student
    ATTRIBUTES
        PRIVATE studentID : Number
        PRIVATE studentName : String
        PRIVATE attempts : List<Attempt>

CONSTRUCTOR(studentID, studentName)
        SET studentID
        SET studentName
        CREATE empty attempts list
END CONSTRUCTOR
METHOD addAttempt(attempt)
        ADD attempt TO attempts
    END METHOD
END CLASS

CLASS Attempt
    ATTRIBUTES
        PRIVATE attemptID : Number
        PRIVATE exam : Exam
        PRIVATE student : Student
        PRIVATE selectedAnswers : Map<Question, String>
        PRIVATE startTime : String
CONSTRUCTOR(attemptID, exam, student, startTime)
        SET attemptID
        SET exam
        SET student
        SET startTime
        CREATE empty selectedAnswers map
END CONSTRUCTOR
METHOD submitAnswer(question, answer, currentTime)
IF currentTime <= exam.timeLimit THEN
            ADD answer TO selectedAnswers WITH question
ELSE
            DISPLAY "Time limit exceeded"
        END IF
END METHOD
METHOD calculateScore()
        SET score = 0
        FOR EACH question IN exam.questions
            IF question.checkAnswer(selectedAnswers[question]) THEN
                SET score = score + question.getPoints()
            END IF
END FOR
        RETURN score
END METHOD
END CLASS
  END
STOP

